{
  "name": "auction-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "법원경매 매각공고 셀프호스팅 리서치 툴킷 (수집·알림·시세 비교)",
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint .",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.16.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.0"
  }
}
