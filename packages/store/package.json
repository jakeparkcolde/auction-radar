{
  "name": "@auction-radar/store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "스토어 드라이버 인터페이스 + SQLite 구현 (prepared statement 전용) + 마이그레이션 러너",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src/migrations/*.sql"],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && node scripts/copy-sql.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
